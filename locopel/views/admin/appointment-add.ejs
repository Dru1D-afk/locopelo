<!DOCTYPE html>
<html>
<head>
  <title>Записи на прием | Админ-панель</title>
  <link rel="stylesheet" href="/css/main.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=Montserrat:ital,wght@0,100..900;1,100..900&family=Play:wght@400;700&family=Roboto:ital,wght@0,100;0,300;0,400;0,500;0,700;0,900;1,100;1,300;1,400;1,500;1,700;1,900&family=Sen:wght@400..800&display=swap" rel="stylesheet">
</head>
<body>
<div class="" style="display: flex; flex-direction: column; align-items: center; min-height: 100vh; justify-content: center; background-color: #A6BEB1; gap: 2rem;">
  <h1 style="color: white;">Добавить запись</h1>

<form method="POST" style="display: flex; flex-direction: column; align-items: center;">
  <div style="display:grid; grid-template-columns:1fr 1fr; gap:20px; max-width:600px;">
    <select name="userId" required style="padding:12px; border:1px solid #ddd; border-radius:8px;">
      <option value="">Выберите пользователя</option>
      <% users.forEach(user => { %>
        <option value="<%= user.id %>"><%= user.name %> (<%= user.phone %>)</option>
      <% }); %>
    </select>
    
    <input name="date" type="date" required style="padding:12px; border:1px solid #ddd; border-radius:8px;">
    
    <input name="master" placeholder="Мастер" required style="padding:12px; border:1px solid #ddd; border-radius:8px;">
    
    <select name="procedure" required style="padding:12px; border:1px solid #ddd; border-radius:8px;">
      <option value="">Процедура</option>
      <option value="Наращивание волос">Наращивание волос</option>
      <option value="Коррекция">Коррекция</option>
      <option value="Снятие">Снятие</option>
      <option value="Консультация">Консультация</option>
    </select>
    
    <textarea name="notes" placeholder="Примечания (необязательно)" style="padding:12px; border:1px solid #ddd; border-radius:8px; grid-column:1/-1; height:100px;"></textarea>
  </div>
  
  <button type="submit" style="background:green; color:white; border:none; padding:15px 30px; border-radius:8px; font-size:16px; margin-top:20px; cursor:pointer;">Добавить запись</button>
</form>

<a href="/admin" style="display:inline-block; background:#6c757d; color:white; padding:10px 20px; text-decoration:none; border-radius:5px; margin-left:10px;">← Назад</a>
</div>
</body>
</html>