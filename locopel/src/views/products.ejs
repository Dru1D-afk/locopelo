<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Студия наращивания волос</title>
  <link rel="stylesheet" href="/css/main.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=Montserrat:ital,wght@0,100..900;1,100..900&family=Play:wght@400;700&family=Roboto:ital,wght@0,100;0,300;0,400;0,500;0,700;0,900;1,100;1,300;1,400;1,500;1,700;1,900&family=Sen:wght@400..800&display=swap" rel="stylesheet">
</head>
<body>
    <nav class="navbar" id="navbar">
        <div class="nav-container">
            <div class="nav-logo">
                <a href="/"><img src="/images/logot.png" alt="LocoPeco" class="logo-text"></a>
                <a href="/"><img src="/images/logo_pelo.png" alt="LocoPeco" class="logo-text lv2"></a>
            </div>
            <ul class="nav-menu" id="nav-menu">
                <li class="nav-item">
                    <a href="/" class="nav-link">Главная</a>
                </li><li class="nav-item">
                    <a href="/extensions" class="nav-link">Наращивание</a>
                </li>
                <li class="nav-item">
                    <a href="/education" class="nav-link">Обучение</a>
                </li>
                
                <li class="nav-item">
                    <a href="/products" class="nav-link active">Товары</a>
                </li>
            </ul>
            <ul class="nav-menu">
                <% if (locals.user) { %>
                    <a href="/profile" class="nav-link"> <%= user.name %></a>
                    <% } else { %>
                        <a href="/auth/login" class="nav-link">Войти</a>
                <% } %>
                <span id="styl"><i class="fa-solid fa-circle-half-stroke"></i></span>
            </ul>
            <div class="hamburger" id="hamburger">
                <span class="bar"></span>
                <span class="bar"></span>
                <span class="bar"></span>
            </div></div>
        </div></nav>

<section class="tovari">
    <div class="container">
<h1>Товары</h1>
<% if (products && products.length > 0) { %>
<div class="product-grid">
  <% products.forEach(product => { %>
    <div class="card" style="border: 1px solid #ddd; padding: 15px; border-radius: 8px; display: flex; flex-direction: column; justify-content: space-between; box-shadow: var(--shadow);">
      <img class="product" alt="product" src="<%= product.imageUrl %>">
      <div class="cardtxt" style="display: flex; flex-direction: column; gap: 3px; padding: 15px;">
      <h3><%= product.title %></h3>
      <p><%= product.description %></p>
      <p><b><%= product.price %> руб.</b></p>
      </div>
      <% if (user) { %>
  <form action="/favorites/toggle" method="POST">
    <input type="hidden" name="productId" value="<%= product.id %>">
    <button class="izb" type="submit">❤️ В избранное</button>
  </form>
<% } else { %>
  <a href="/auth/login" style="color: white; text-decoration: none; background-color: #A6BEB1; padding: 8px 16px; border-radius: 5px;">Войдите, чтобы добавить в избранное</a>
<% } %>
    </div>
  <% }) %>
</div>
<% } else { %>
    <div style="text-align: center; padding: 40px; color: #6c757d;">
      <p>Товаров пока нет</p>
      <p>Администратор добавит товары</p>
    </div>
  <% } %>
    </div>
</section>


<footer class="footer" id="footr">
        <div class="container">
            <div class="footer-content">
                <div class="footer-section">
                    <div class="footer-logo">
                        <a href="/"><img src="images/logot.png" alt="LocoPeco" class="logo-text"></a>
                    </div>
                    
                </div><div class="soc">
                    <a class="ss svk" href="https://vk.com/locopelo_orenburg"><i class="fa-brands fa-vk"></i></a>
                    <a class="ss ws" href="https://wa.me/79033664261"><i class="fa-brands fa-whatsapp"></i></a>
                    <a class="ss stg" href="https://t.me/breigbali"><i class="fa-brands fa-telegram"></i></a>
                 </div>
                <a href="tel:+79033664261" class="footer-description">+7 (903) 366-42-61<br>
                        Консультация</a>
            </div>

            <div class="footer-bottom">
                <div class="fb-grid">
                <div class="fu">
                    <a href="https://locopelo.ru/assets/landing/files/personal-data-processing-policy-2025.pdf">Политика конфиденциальности</a>
                </div>
                <div class="fu">
                    <a href="https://locopelo.ru/assets/landing/files/consent-to-processing-of-personal-data-2025.pdf">Согласие на обработку перс. данных</a>
                </div>
                <div class="fu">
                    <a href="https://locopelo.ru/assets/landing/files/contract-offer_training-for-building-up-2025.pdf">Договор-оферта</a>
                </div>
            </div>
                <p>© 2026. Все права защищены.</p>
            </div>
        </div>
    </footer>
<script src="/js/main.js"></script>
</body>
</html>